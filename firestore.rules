rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function myProfile() {
      return signedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : null;
    }

    function myRole() {
      return signedIn() && myProfile() != null ? myProfile().role : '';
    }

    function myCompanyId() {
      return signedIn() && myProfile() != null
        ? (myProfile().companyId != null ? myProfile().companyId : (myProfile().clientId != null ? myProfile().clientId : ''))
        : '';
    }

    function myAgencyId() {
      return signedIn() && myProfile() != null && myProfile().agencyId != null
        ? myProfile().agencyId
        : '';
    }

    function myWorkerId() {
      return signedIn() && myProfile() != null
        ? (myProfile().workerId != null ? myProfile().workerId : (myProfile().employeeId != null ? myProfile().employeeId : ''))
        : '';
    }

    function myAssignedSiteIds() {
      return signedIn() && myProfile() != null && myProfile().assignedSiteIds is list
        ? myProfile().assignedSiteIds
        : [];
    }

    function isPlatformOwner() {
      return signedIn() && myRole() == 'platformOwner';
    }

    function isAdminLike() {
      return signedIn() && myRole() in ['admin', 'agencyOwner', 'agencyAdmin', 'platformOwner'];
    }

    function isManagerLike() {
      return signedIn() && (myRole() == 'manager' || isAdminLike());
    }

    function isClientManager() {
      return signedIn() && myRole() == 'clientManager';
    }

    function isEmployeeAuth() {
      return signedIn() && myRole() in ['employee', 'worker'];
    }

    function sameCompany(data) {
      return data != null && myCompanyId() != '' && (
        (data.companyId != null && data.companyId == myCompanyId()) ||
        (data.clientId != null && data.clientId == myCompanyId())
      );
    }

    function sameAgency(data) {
      return data != null && myAgencyId() != '' && data.agencyId != null && data.agencyId == myAgencyId();
    }

    function sameScope(data) {
      return isPlatformOwner() || sameCompany(data) || sameAgency(data);
    }

    function clientManagerScope(data) {
      return data != null &&
        isClientManager() &&
        sameCompany(data) &&
        (
          myAssignedSiteIds().size() == 0 ||
          (data.siteId != null && data.siteId in myAssignedSiteIds()) ||
          (data.assignedSiteId != null && data.assignedSiteId in myAssignedSiteIds())
        );
    }

    function managerReadScope(data) {
      return signedIn() && (
        (isManagerLike() && sameScope(data)) ||
        clientManagerScope(data)
      );
    }

    match /companies/{companyId} {
      allow read: if signedIn() && (
        isPlatformOwner() ||
        companyId == myCompanyId() ||
        sameScope(resource.data)
      );
      allow create: if isAdminLike() && (
        companyId == myCompanyId() ||
        sameScope(request.resource.data)
      );
      allow update, delete: if isAdminLike() && (
        companyId == myCompanyId() ||
        sameScope(resource.data)
      );
    }

    match /agencies/{agencyId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdminLike();
    }

    match /users/{userId} {
      allow read: if signedIn() && (
        request.auth.uid == userId ||
        (isManagerLike() && sameScope(resource.data))
      );
      allow create, update: if isAdminLike() && sameScope(request.resource.data);
      allow delete: if isAdminLike() && sameScope(resource.data);
    }

    match /employees/{employeeId} {
      allow read: if managerReadScope(resource.data);
      allow create: if isManagerLike() && sameScope(request.resource.data);
      allow update, delete: if isManagerLike() && sameScope(resource.data);
    }

    match /workers/{workerId} {
      allow read: if managerReadScope(resource.data);
      allow create: if isManagerLike() && sameScope(request.resource.data);
      allow update, delete: if isManagerLike() && sameScope(resource.data);
    }

    match /punches/{punchId} {
      allow read: if managerReadScope(resource.data) || (
        isEmployeeAuth() &&
        sameScope(resource.data) &&
        (
          (resource.data.employeeId != null && resource.data.employeeId == myWorkerId()) ||
          (resource.data.workerId != null && resource.data.workerId == myWorkerId())
        )
      );
      allow create: if isManagerLike() && sameScope(request.resource.data);
      allow update, delete: if managerReadScope(resource.data);
    }

    match /punch_edits/{editId} {
      allow create: if isManagerLike() && sameScope(request.resource.data);
      allow read: if isManagerLike() && sameScope(resource.data);
      allow update, delete: if false;
    }

    match /timesheets/{timesheetId} {
      allow read: if managerReadScope(resource.data) || (
        isEmployeeAuth() &&
        sameScope(resource.data) &&
        (
          (resource.data.employeeId != null && resource.data.employeeId == myWorkerId()) ||
          (resource.data.workerId != null && resource.data.workerId == myWorkerId())
        )
      );
      allow create, update: if managerReadScope(request.resource.data) || (isManagerLike() && sameScope(request.resource.data));
      allow delete: if isAdminLike() && sameScope(resource.data);
    }

    match /missedPunchRequests/{requestId} {
      allow create: if (isEmployeeAuth() &&
        request.resource.data.uid == request.auth.uid &&
        sameCompany(request.resource.data) &&
        request.resource.data.status == 'pending') ||
        (isManagerLike() && sameScope(request.resource.data));

      allow read: if (isEmployeeAuth() && resource.data.uid == request.auth.uid) ||
        managerReadScope(resource.data);

      allow update: if managerReadScope(resource.data);
      allow delete: if isManagerLike() && sameScope(resource.data);
    }

    match /punchRequests/{requestId} {
      allow create: if (isEmployeeAuth() &&
        request.resource.data.uid == request.auth.uid &&
        sameCompany(request.resource.data) &&
        request.resource.data.status == 'pending') ||
        (isManagerLike() && sameScope(request.resource.data));

      allow read: if (isEmployeeAuth() && resource.data.uid == request.auth.uid) ||
        managerReadScope(resource.data);

      allow update: if managerReadScope(resource.data);
      allow delete: if isManagerLike() && sameScope(resource.data);
    }

    match /auditLogs/{logId} {
      allow create: if managerReadScope(request.resource.data);
      allow read: if managerReadScope(resource.data);
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
