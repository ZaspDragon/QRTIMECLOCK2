# QRTimeClock2 is currently configured with frontend-safe Firebase web config in firebase-config.js.
# If you later move this app to Vite, keep all browser-exposed values on VITE_ variables only.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_FUNCTIONS_BASE_URL=
